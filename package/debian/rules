#!/usr/bin/make -f
include /usr/share/dpkg/pkg-info.mk
export DEB_VERSION
export DEB_HOST_MULTIARCH
DATE := $(shell date +"%y.%m.%d")
DISTRIBUTION := $(shell sed -n "s/^VERSION_CODENAME=//p" /etc/os-release)

clean:
	dh_clean

build:
	@# Do nothing

binary:
	dh_prep
	dh_install
	dh_link
	dh_installdocs
	dh_installchangelogs
	dh_compress
	dh_fixperms
	dh_makeshlibs
	dh_shlibdeps
	dh_installsysusers
	dh_installsystemd
	dh_installtmpfiles
	dh_installdeb
	dh_gencontrol -- -v"$(DEB_VERSION)~$(DISTRIBUTION)"
	dh_md5sums
	dh_builddeb
